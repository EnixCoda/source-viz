{
  "name": "source-viz",
  "version": "1.0.0",
  "description": "Visualize JavaScript/TypeScript import dependency graphs — in the browser or from the CLI",
  "author": "EnixCoda",
  "license": "MIT",
  "homepage": "https://srcviz.enix.one",
  "repository": {
    "type": "git",
    "url": "https://github.com/EnixCoda/source-viz.git"
  },
  "keywords": [
    "dependency-graph",
    "visualization",
    "static-analysis",
    "typescript",
    "javascript",
    "imports",
    "cli",
    "d3"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "generate-demo": "tsx scripts/generate-demo-data.ts",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "preview": "vite preview",
    "source-viz": "tsx cli/index.ts",
    "build:cli": "tsup",
    "prepublishOnly": "npm run build:cli",
    "verify-precache": "node scripts/verify-precache.cjs"
  },
  "prettier": {
    "printWidth": 120
  },
  "dependencies": {
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@chakra-ui/icons": "^2.2.4",
    "@chakra-ui/react": "^2.10.9",
    "@chakra-ui/system": "^2.5.8",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@oxc-parser/binding-wasm32-wasi": "^0.129.0",
    "@react-hook/resize-observer": "^1.2.6",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/babel__traverse": "^7.20.1",
    "@types/d3": "^7.4.0",
    "@types/d3-force": "^3.0.10",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/path-browserify": "^1.0.2",
    "@types/react-window": "^2.0.0",
    "commander": "^14.0.3",
    "d3": "^7.9.0",
    "d3-force": "^3.0.0",
    "d3-interpolate": "^3.0.1",
    "d3-scale-chromatic": "^3.1.0",
    "framer-motion": "^12.38.0",
    "oxc-parser": "^0.129.0",
    "path-browserify": "^1.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-iifc": "^1.2.1",
    "react-use": "^17.6.0",
    "react-window": "^2.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "bin": {
    "source-viz": "dist-cli/index.cjs"
  },
  "files": [
    "dist-cli/"
  ]
}
